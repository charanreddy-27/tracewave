# Direct WebSocket URL to the Tracewave API (the /ws endpoint).
# Dev default if unset: ws://<current-host>:8000/ws
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8000/ws

# Port used to build the default dev WS URL when NEXT_PUBLIC_WS_URL is unset.
# NEXT_PUBLIC_WS_PORT=8000

# Origin the Next dev server proxies /api/* REST calls to (see next.config.mjs).
# BACKEND_ORIGIN=http://127.0.0.1:8000
