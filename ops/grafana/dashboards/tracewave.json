{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Tracewave · Pipeline Health",
  "uid": "tracewave-health",
  "tags": ["tracewave"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Events / sec (latest window)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#34e3c8" }, "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "max(tw_events_per_sec)", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Anomalies (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#f4596b" }, "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(tw_anomalies_total[5m]))", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dropped events (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "#f3b24c" }, "unit": "short" }, "overrides": [] },
      "targets": [{ "expr": "sum(increase(tw_events_dropped_total[5m]))", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Processing lag (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] } }, "overrides": [] },
      "targets": [{ "expr": "max(tw_processing_lag_seconds)", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput — ingested vs processed (ev/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(rate(tw_events_ingested_total[1m]))", "legendFormat": "ingested", "refId": "A" },
        { "expr": "sum(rate(tw_events_processed_total[1m]))", "legendFormat": "processed", "refId": "B" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Anomalies by severity (per min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (severity) (increase(tw_anomalies_total[1m]))", "legendFormat": "{{severity}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Detector fires (per min)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (detector) (increase(tw_detector_fired_total[1m]))", "legendFormat": "{{detector}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Window processing time p95 (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(tw_window_process_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" }
      ]
    }
  ]
}
