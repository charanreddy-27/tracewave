# Optional overrides for the Docker stack (read by docker-compose.yml).
# Copy to .env and edit. All backend settings use the TW_ prefix.

# Wikimedia requires a descriptive User-Agent with a contact — set your own:
# TW_USER_AGENT=Tracewave/0.1 (you@example.com)

# Switch firehose source (currently: wikimedia)
# TW_SOURCE=wikimedia

# Detector sensitivity (lower threshold = more sensitive)
# TW_ZSCORE_THRESHOLD=3.2
# TW_EWMA_THRESHOLD=3.2
# TW_HST_THRESHOLD=0.85

# Replay an offline recording instead of the live stream
# TW_REPLAY_FILE=/app/data/sample.jsonl
# TW_REPLAY_SPEED=1
